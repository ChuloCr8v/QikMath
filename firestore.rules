rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helpers
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Entity Validations
    function isValidUser(data) {
      return data.uid is string && data.uid.size() <= 128 &&
             data.displayName is string && data.displayName.size() >= 1 && data.displayName.size() <= 50 &&
             data.avatarSeed is string && data.avatarSeed.size() <= 128 &&
             (!('personalBest' in data) || data.personalBest is number) &&
             data.updatedAt is timestamp && data.updatedAt == request.time;
    }

    function isValidScore(data) {
      return data.name is string && data.name.size() >= 1 && data.name.size() <= 50 &&
             data.score is number && data.score >= 0 &&
             data.difficulty is string && data.difficulty in ['EASY', 'NORMAL', 'HARD'] &&
             data.accuracy is number && data.accuracy >= 0 && data.accuracy <= 100 &&
             data.timestamp is number &&
             data.avatarSeed is string && data.avatarSeed.size() <= 128 &&
             ('userId' in data) && data.userId is string && data.userId == request.auth.uid &&
             (!('levelReached' in data) || data.levelReached is number);
    }

    // Collections
    match /users/{userId} {
      allow get: if isSignedIn();
      allow create, update: if isOwner(userId) && isValidUser(incoming());
    }

    match /scores/{scoreId} {
      allow list: if true; // Public leaderboard
      allow get: if true;
      allow create: if isValidScore(incoming());
      // Scores are immutable
      allow update, delete: if false;
    }
  }
}
